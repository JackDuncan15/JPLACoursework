<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:alpha="1"
    tools:context=".MainActivity">
    <!-- Background image -->
    <ImageView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:src="@drawable/background_image_blurred"
        android:scaleType="centerCrop" />


    <!-- Dark overlay -->
    <View
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#CC0F213A" />


    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="20dp"


        android:layout_marginTop="40dp"
        android:orientation="vertical"

        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/txt_Title">


        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardHiragana"
            android:layout_width="match_parent"
            android:layout_height="140dp"
            android:layout_marginBottom="20dp"

            android:clickable="true"
            android:focusable="true"
            android:foreground="?attr/selectableItemBackground"

            app:cardBackgroundColor="#24344D"
            app:cardCornerRadius="20dp"
            app:cardElevation="8dp"
            app:strokeColor="#304560"
            app:strokeWidth="1dp"

            tools:layout_editor_absoluteX="20dp"
            tools:layout_editor_absoluteY="566dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingHorizontal="16dp"
                android:paddingVertical="12dp">

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="72dp"
                    android:layout_height="72dp"

                    app:cardBackgroundColor="#2F4565"
                    app:cardCornerRadius="16dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"

                        android:gravity="center"

                        android:text="あ"
                        android:textColor="#FFC84D"
                        android:textSize="40sp"
                        android:textStyle="bold" />

                </com.google.android.material.card.MaterialCardView>


                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"

                    android:layout_marginStart="16dp"
                    android:layout_weight="1"

                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"

                        android:text="Hiragana Practice"
                        android:textColor="@android:color/white"
                        android:textSize="22sp"
                        android:textStyle="bold" />


                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"

                        android:text="Learn all 46 characters"
                        android:textColor="#BFC7D5"
                        android:textSize="16sp" />


                    <com.google.android.material.progressindicator.LinearProgressIndicator
                        android:layout_width="match_parent"
                        android:layout_height="8dp"

                        android:layout_marginTop="12dp"

                        android:max="46"
                        android:progress="42"

                        app:trackCornerRadius="4dp"
                        app:trackThickness="8dp" />

                </LinearLayout>


                <com.google.android.material.button.MaterialButton
                    android:layout_width="48dp"
                    android:layout_height="48dp"

                    android:clickable="false"
                    android:focusable="false"

                    android:gravity="center"
                    android:padding="0dp"
                    android:text=">"
                    android:textColor="@android:color/white"
                    android:textSize="22sp"
                    app:cornerRadius="24dp" />


            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>


        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardKatakana"
            android:layout_width="match_parent"
            android:layout_height="140dp"
            android:layout_marginBottom="20dp"

            android:clickable="true"
            android:focusable="true"
            android:foreground="?attr/selectableItemBackground"
            app:cardBackgroundColor="#24344D"
            app:cardCornerRadius="20dp"

            app:cardElevation="8dp"
            app:strokeColor="#304560"
            app:strokeWidth="1dp"

            tools:layout_editor_absoluteX="20dp"
            tools:layout_editor_absoluteY="566dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingHorizontal="16dp"
                android:paddingVertical="12dp">

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="72dp"
                    android:layout_height="72dp"

                    app:cardBackgroundColor="#2F4565"
                    app:cardCornerRadius="16dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"

                        android:gravity="center"

                        android:text="ア"
                        android:textColor="#FFC84D"
                        android:textSize="40sp"
                        android:textStyle="bold" />

                </com.google.android.material.card.MaterialCardView>


                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"

                    android:layout_marginStart="16dp"
                    android:layout_weight="1"

                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"

                        android:text="Katakana Practice"
                        android:textColor="@android:color/white"
                        android:textSize="22sp"
                        android:textStyle="bold" />


                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"

                        android:text="Learn all 46 characters"
                        android:textColor="#BFC7D5"
                        android:textSize="16sp" />


                    <com.google.android.material.progressindicator.LinearProgressIndicator
                        android:layout_width="match_parent"
                        android:layout_height="8dp"

                        android:layout_marginTop="12dp"

                        android:max="46"
                        android:progress="42"

                        app:trackCornerRadius="4dp"
                        app:trackThickness="8dp" />

                </LinearLayout>


                <com.google.android.material.button.MaterialButton
                    android:layout_width="48dp"
                    android:layout_height="48dp"

                    android:clickable="false"
                    android:focusable="false"

                    android:gravity="center"
                    android:padding="0dp"
                    android:text=">"
                    android:textColor="@android:color/white"
                    android:textSize="22sp"
                    app:cornerRadius="24dp" />


            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>


        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardDictionary"
            android:layout_width="match_parent"
            android:layout_height="140dp"
            android:layout_marginBottom="20dp"

            android:clickable="true"
            android:focusable="true"
            android:foreground="?attr/selectableItemBackground"
            app:cardBackgroundColor="#24344D"
            app:cardCornerRadius="20dp"

            app:cardElevation="8dp"
            app:strokeColor="#304560"
            app:strokeWidth="1dp"

            tools:layout_editor_absoluteX="20dp"
            tools:layout_editor_absoluteY="566dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingHorizontal="16dp"
                android:paddingVertical="12dp">

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="72dp"
                    android:layout_height="72dp"

                    app:cardBackgroundColor="#2F4565"
                    app:cardCornerRadius="16dp">

                    <ImageView
                        android:layout_width="48dp"
                        android:layout_height="48dp"

                        android:layout_gravity="center"

                        android:scaleType="centerInside"

                        android:src="@drawable/book" />

                </com.google.android.material.card.MaterialCardView>


                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"

                    android:layout_marginStart="16dp"
                    android:layout_weight="1"

                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"

                        android:text="Dictionary"
                        android:textColor="@android:color/white"
                        android:textSize="22sp"
                        android:textStyle="bold" />


                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"

                        android:text="Search japanese word\nkana and kanji"
                        android:textColor="#BFC7D5"
                        android:textSize="16sp" />
                </LinearLayout>


                <com.google.android.material.button.MaterialButton
                    android:layout_width="48dp"
                    android:layout_height="48dp"

                    android:clickable="false"
                    android:focusable="false"

                    android:gravity="center"
                    android:padding="0dp"
                    android:text=">"
                    android:textColor="@android:color/white"
                    android:textSize="22sp"
                    app:cornerRadius="24dp" />


            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>


    </LinearLayout>


    <ImageView
        android:id="@+id/img_CornerLogo"
        android:layout_width="62dp"
        android:layout_height="55dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.005"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintVertical_bias="0.004"
        app:srcCompat="@drawable/chatgpt_image_dec_1__2025__10_26_16_pm" />

    <TextView
        android:id="@+id/txt_Title"
        android:layout_width="171dp"
        android:layout_height="58dp"
        android:fontFamily="@font/noto_sans_jp_medium"
        android:text="Kana Trainer "
        android:textAlignment="center"
        android:textColor="#FDCC02"
        android:textSize="24sp"
        android:textStyle="bold"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintVertical_bias="0.004" />

</androidx.constraintlayout.widget.ConstraintLayout>