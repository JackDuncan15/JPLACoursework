<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:alpha="0.8"
    android:background="#FFFFFF"
    tools:context=".MainActivity">

    <ImageView
        android:id="@+id/img_Background"
        android:layout_width="592dp"
        android:layout_height="1022dp"
        android:layout_marginStart="16dp"
        android:alpha="0.9"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.294"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintVertical_bias="0.591"
        app:srcCompat="@drawable/background_image_blurred" />

    <androidx.appcompat.widget.SearchView
        android:id="@+id/s_SearchBar"
        android:layout_width="321dp"
        android:layout_height="35dp"
        android:alpha="1"
        android:background="@drawable/background"
        android:backgroundTint="#FFFFFF"
        android:outlineAmbientShadowColor="#000000"
        android:outlineProvider="bounds"
        android:queryHint="Search"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.388"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintVertical_bias="0.117" />

    <ImageView
        android:id="@+id/img_CornerLogo"
        android:layout_width="62dp"
        android:layout_height="55dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.005"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintVertical_bias="0.004"
        app:srcCompat="@drawable/chatgpt_image_dec_1__2025__10_26_16_pm" />

    <TextView
        android:id="@+id/txt_Title"
        android:layout_width="171dp"
        android:layout_height="58dp"
        android:fontFamily="@font/noto_sans_jp_medium"
        android:text="Kana Trainer "
        android:textAlignment="center"
        android:textColor="#FDCC02"
        android:textSize="24sp"
        android:textStyle="bold"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintVertical_bias="0.004" />

    <Button
        android:id="@+id/btn_Hiragana"
        android:layout_width="317dp"
        android:layout_height="80dp"
        android:backgroundTint="#2C3E50"
        android:elevation="3dp"
        android:text="Hiragana Practice  あ"
        android:textColor="#FFC82E"
        android:textSize="20sp"
        app:cornerRadius="10dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.414"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintVertical_bias="0.308"
        app:strokeColor="#1F2B38"
        app:strokeWidth="2dp" />

    <Button
        android:id="@+id/btn_Katakana"
        android:layout_width="317dp"
        android:layout_height="80dp"
        android:backgroundTint="#2C3E50"
        android:elevation="3dp"
        android:text="Katakana Practice  ア"
        android:textColor="#FFC82E"
        android:textSize="20sp"
        app:cornerRadius="10dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="@+id/btn_Hiragana"
        app:layout_constraintStart_toStartOf="@+id/btn_Hiragana"
        app:layout_constraintTop_toBottomOf="@+id/btn_Hiragana"
        app:layout_constraintVertical_bias="0.17"
        app:strokeColor="#1F2B38"
        app:strokeWidth="2dp" />

    <Button
        android:id="@+id/btn_Dictionary"
        android:layout_width="317dp"
        android:layout_height="80dp"
        android:backgroundTint="#2C3E50"
        android:elevation="3dp"
        android:text=" Visit Dictionary  辞書"
        android:textColor="#FFC82E"
        android:textSize="20sp"
        app:cornerRadius="10dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="@+id/btn_Katakana"
        app:layout_constraintStart_toStartOf="@+id/btn_Katakana"
        app:layout_constraintTop_toBottomOf="@+id/btn_Katakana"
        app:layout_constraintVertical_bias="0.299"
        app:strokeColor="#1F2B38"
        app:strokeWidth="2dp" />

</androidx.constraintlayout.widget.ConstraintLayout>