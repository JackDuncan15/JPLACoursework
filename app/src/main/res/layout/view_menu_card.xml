<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/cardHiragana"
        android:layout_width="match_parent"
        android:layout_height="120dp"
        android:layout_marginHorizontal="20dp"

        app:cardBackgroundColor="#24344D"
        app:cardCornerRadius="20dp"
        app:cardElevation="8dp"
        app:strokeColor="#304560"
        app:strokeWidth="1dp"

        tools:layout_editor_absoluteX="20dp"
        tools:layout_editor_absoluteY="566dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:padding="16dp">

            <com.google.android.material.card.MaterialCardView
                android:layout_width="72dp"
                android:layout_height="72dp"

                app:cardCornerRadius="16dp"
                app:cardBackgroundColor="#2F4565">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"

                    android:gravity="center"

                    android:text="あ"
                    android:textSize="40sp"
                    android:textStyle="bold"
                    android:textColor="#FFC84D"/>

            </com.google.android.material.card.MaterialCardView>


            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"

                android:layout_weight="1"
                android:orientation="vertical"

                android:layout_marginStart="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"

                    android:text="Hiragana Practice"
                    android:textSize="22sp"
                    android:textStyle="bold"
                    android:textColor="@android:color/white"/>


                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"

                    android:text="Learn all 46 characters"
                    android:textSize="16sp"
                    android:textColor="#BFC7D5"/>


                <com.google.android.material.progressindicator.LinearProgressIndicator
                    android:layout_width="match_parent"
                    android:layout_height="8dp"

                    android:layout_marginTop="12dp"

                    android:max="46"
                    android:progress="42"

                    app:trackThickness="8dp"
                    app:trackCornerRadius="4dp"/>

            </LinearLayout>


            <com.google.android.material.button.MaterialButton
                android:layout_width="48dp"
                android:layout_height="48dp"

                android:text=">"
                android:textSize="22sp"

                app:cornerRadius="24dp"/>


        </LinearLayout>

    </com.google.android.material.card.MaterialCardView>

</androidx.constraintlayout.widget.ConstraintLayout>